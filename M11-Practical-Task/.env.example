# Copy this file to .env and adjust if needed.
# The application reads these automatically at startup via spring-dotenv.
#
# Ollama runs locally and needs no API key. Defaults are fine for local dev.

#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.2
#CHAT_SYSTEM_PROMPT=You are a helpful, concise assistant.
#SQLITE_DB_PATH=chatbot.db
